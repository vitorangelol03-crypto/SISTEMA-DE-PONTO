# Sistema de Ponto — exemplo de .env
# Copie pra .env e preencha com valores reais.
# .env está no .gitignore (não comitar com keys reais).

# ─── Obrigatórias pro frontend (runtime) ─────────────────────────────────────

VITE_SUPABASE_URL=https://flcncdidxmmornkgkfbb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ─── Opcional — apenas pra testes E2E que validam isolamento RLS ─────────────
#
# Necessária pra tests/cleanup.ts:getClient() bypassar RLS em queries diretas
# usadas por specs `25-multi-company-isolation` e `26-multi-company-ui-isolation`
# (teste 6). Sem ela, getClient() faz fallback pra ANON_KEY e essas specs
# retornam resultados vazios após Fase 11 (RLS ativo em 47 tabelas).
#
# Pegue em: Supabase Dashboard → Settings → API → "service_role" key (Reveal).
# NUNCA expor essa key pro frontend em produção — ela bypassa todas as RLS policies.

SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
